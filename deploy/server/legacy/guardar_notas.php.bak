<?php


function sanitize_input($data) {
    // Elimina espacios al inicio y al final de la cadena
    $data = trim($data);
    // Elimina barras invertidas
    $data = stripslashes($data);
    // Convierte caracteres especiales en entidades HTML
    $data = htmlspecialchars($data, ENT_QUOTES, 'UTF-8');
    return $data;
}
//header("Access-Control-Allow-Origin: *");
require_once("datos_conexion.php");
require("headers.php");
$mysqli = new mysqli($host, $user, $pass, $database);

$mysqli->query("SET NAMES utf8");
$mysqli->set_charset('utf8');
date_default_timezone_set('America/Bogota');

// Obtener la fecha y hora del servidor
$fechahora = date("Y-m-d H:i:s");

$notas = json_decode(file_get_contents("php://input"), true);

$sql="select estado from estadoNotas";
//echo ($mysqli->query($sql))->fetch_assoc()['estado'];exit(0);  
try {
    $estadoResult = $mysqli->query($sql);
    $estadoRow = $estadoResult ? $estadoResult->fetch_assoc() : null;
    if ($estadoRow && isset($estadoRow['estado']) && $estadoRow['estado'] == '0') {
        echo json_encode(array("msg" => "Prohibido"));
        $mysqli->close();
        exit(0);
    }
} catch (mysqli_sql_exception $e) {
    error_log("[guardar_notas] estadoNotas no disponible, se permite guardar: " . $e->getMessage());
}

$total = count($notas);
$sqli = "REPLACE INTO notas (%s) VALUES %s";
$values = "";
$cantidad = 0;
$i = 0;
$sql = "";
$estu="";
foreach ($notas[0] as $key => $value) $cantidad++;

$array = range(1, 12);
/* foreach ($notas as $nota) {
    for ($j = 1; $j <= 12; $j++) {
        echo $nota['estudiante']."=>".$nota['aspecto' . $j] . PHP_EOL;
      }
} */
for ($j = 1; $j <= 12; $j++) {
    $na = false;
    $ik = 0;
    $fila = 0;
    foreach ($notas as $nota) {
        //echo $nota['estudiante']."=>".$nota['aspecto' . $j] . PHP_EOL;
        $val = $nota['nota' . $j];
        //echo json_encode(array("nota".$j=>$val,"aspecto".$j=>$nota['aspecto' . $j])). PHP_EOL;
        if (($val !== "") && ($val !== null)) {
            $na = true;
            $ik = $j;
            break;
        }
    }
    $encontrado = false;
    if ($na) {
        foreach ($notas as $nota) {
            $estu= $nota['estudiante'];
            $aspecto = $nota['aspecto' . $ik];
            if (($aspecto === "") || ($aspecto === null)) {
                $encontrado = true;
                $fila = $ik;
                break;
            }
        }
        if ($encontrado) {
            echo json_encode(array("msg" => "error_de_aspecto", "info_aspecto" => "Falta aspecto en la nota  $j. No se ha guardado ninguna nota de este aspecto. Por favor asigne el aspecto para porder guardar las notas en el aspecto $j.","estudiante"=>$estu));
            exit(0);
        }
    }
}

foreach ($notas as $nota) {
    $estudiante_id = $mysqli->real_escape_string($nota['estudiante']);
    $grado_nota = $mysqli->real_escape_string($nota['grado']);
    $nota_year = isset($nota['year']) ? $mysqli->real_escape_string($nota['year']) : date('Y');

    // Verify student's grade for the current year in estugrupos
    $verification_sql = "SELECT COUNT(*) FROM estugrupos WHERE estudiante = '$estudiante_id' AND grado = '$grado_nota' AND year = '$nota_year'";
    $verification_result = $mysqli->query($verification_sql);
    if ($verification_result && $verification_result->fetch_row()[0] > 0) {
        // Student belongs to the grade for the current year, proceed with REPLACE INTO
        $k = 0;
        $campos = "";
        $valores = "";


        foreach ($nota as $key => $value) {
            /*  echo json_encode(array('key'=>$key,'vkey'=>strpos($key,'estudiante')));
                exit(0);  */

            if ($k < $cantidad - 1) {
                $campos .= sprintf("%s,", $key);
                if (($value != "") && ($value != "0.00"))
                    $valores .= sprintf("'%s',", $value);
                else
                    $valores .= sprintf("null,");
            } else {
                $campos .= sprintf("%s", $key);
                if (($value != "") && ($value != "0.00"))
                    $valores .= sprintf("'%s'", $value);
                else
                    $valores .= sprintf("null");
            }
            $k++;
        }
        /*  if($i<$total-1)
        $values.=sprintf("(%s),",$valores);
        else*/
        $values = sprintf("(%s)", $valores);
        $i++;
        $cons = sprintf($sqli, $campos, $values);
        $sql .= sprintf("%s;\n", $cons);
    } else {
        // Log or handle cases where student does not belong to the grade for the current year
        error_log("Skipping REPLACE INTO for student $estudiante_id in grade $grado_nota for year $nota_year: Mismatch in estugrupos.");
    }
}
$sql = sprintf($sql, $campos, $values);
/* echo json_encode(array("msg" => "Exito", "sql" => $sql));
exit(0); */
if ($mysqli->multi_query($sql)) {
    echo json_encode(array("msg" => "Exito"));
} else
    echo json_encode(array("msg" => "Error", "error" => sprintf("Mensaje: %s", $mysqli->error), "sql" => $sql));
$mysqli->close();
