{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "eqeqeq": "error",
    "curly": ["error", "multi-line"],
    "no-var": "error",
    "prefer-const": "error",
    "prefer-template": "warn",
    "no-duplicate-imports": "error"
  }
}
