# ============================================================
# SELECTOR DE BASE DE DATOS
# Cambia DB_MODE entre local / cloud para elegir
# ============================================================
DB_MODE=local

# ============================================================
# CONFIGURACIÓN LOCAL
# ============================================================
DB_HOST_LOCAL=localhost
DB_NAME_LOCAL=occi
DB_USER_LOCAL=root
DB_PASS_LOCAL=

# ============================================================
# CONFIGURACIÓN NUBE
# ============================================================
DB_HOST_CLOUD=your-cloud-host.com
DB_NAME_CLOUD=your_cloud_db
DB_USER_CLOUD=your_cloud_user
DB_PASS_CLOUD=your_cloud_password

# Aplicación
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000

# Seguridad
SESSION_SECRET=change-this-to-a-random-string

# CORS
CORS_ORIGIN=http://localhost:3000
